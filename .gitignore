/kapkan
/bin/
/dist/
*.test
*.out
*.prof
.DS_Store
files.zip

# Monorepo generated paths (populated at build, never committed)
# console/ is the canonical operator-UI source; the build copies it here so the
# engine binary can go:embed it.
engine/internal/api/static/
# engine binary (built into engine/ by make build)
/engine/kapkan
# the site build copies the canonical top-level docs/ here for Next to render
site/frontend/content/docs/

# auto-release hook: local credentials + runtime state at the monorepo-root
# .tooling (never commit). Site-relative ignores live in site/.gitignore.
.tooling/release.env
.tooling/release.log
.tooling/release-state.json
.tooling/release.disabled
.tooling/.release.lock
